# ----- Database (PostgreSQL + PostGIS) -----
POSTGRES_USER=morider
POSTGRES_PASSWORD=morider_secret
POSTGRES_DB=morider
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Composed connection string used by Go services
DATABASE_URL=postgres://morider:morider_secret@postgres:5432/morider?sslmode=disable

# ----- Redis -----
REDIS_URL=redis://redis:6379/0

# ----- NATS -----
NATS_URL=nats://nats:4222

# ----- Runtime -----
# development | production. When production, JWT_SECRET must be changed from the
# default below or the services refuse to start.
APP_ENV=development

# ----- Auth -----
JWT_SECRET=change_me_in_production
JWT_TTL_HOURS=72

# ----- Rate limiting (per client IP, every service) -----
# Token bucket: RPS sustained rate, BURST short spike allowance.
RATE_LIMIT_RPS=50
RATE_LIMIT_BURST=100

# ----- Routing engine (OSRM-compatible) -----
# Development default is the public OSRM demo (rate-limited, "driving" only).
# To self-host: `make osrm-data && make osrm-up`, then set ROUTING_URL=http://osrm:5000.
# For a motorcycle-tuned engine (scenic roads, highway penalty): build with
# `make osrm-data OSRM_PROFILE=motorcycle` (see docs/routing.md). Self-hosted only.
ROUTING_URL=https://router.project-osrm.org
ROUTING_PROFILE=driving
# Region name for the self-hosted OSRM data/service (see Makefile OSRM_* vars).
OSRM_REGION=turkey

# ----- Elevation (DEM) -----
# OpenTopoData-compatible endpoint, dataset in the URL. The public instance is
# rate-limited (1 req/sn, 1000/gün); self-host for production.
ELEVATION_URL=https://api.opentopodata.org/v1/srtm90m

# ----- Service ports -----
GATEWAY_PORT=8080
AUTH_PORT=8081
USER_PORT=8082
RIDE_PORT=8083
ROUTE_PORT=8084
REWARD_PORT=8085
TELEMETRY_PORT=8086
FEED_PORT=8087

# ----- Internal service URLs (used by api-gateway) -----
AUTH_SERVICE_URL=http://auth:8081
USER_SERVICE_URL=http://user:8082
RIDE_SERVICE_URL=http://ride:8083
ROUTE_SERVICE_URL=http://route:8084
REWARD_SERVICE_URL=http://reward:8085
TELEMETRY_SERVICE_URL=http://telemetry:8086
FEED_SERVICE_URL=http://feed:8087

# ----- Feed (photo uploads) -----
# Directory where the feed service stores uploaded photos (mounted volume in Docker).
UPLOAD_DIR=/data/uploads

# ----- Grafana (dashboards at http://localhost:3000) -----
# Login for the Grafana UI. Datasources/dashboards are auto-provisioned.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ----- Mobile (Expo) -----
# When running on a device, replace localhost with your machine's LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:8080
