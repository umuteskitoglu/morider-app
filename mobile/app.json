{
  "expo": {
    "name": "Morider App",
    "slug": "morider-app",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "morider",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.morider.mobile",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSLocationWhenInUseUsageDescription": "Morider sürüşlerinizi kaydetmek için konumunuza erişir.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Morider arka planda sürüşlerinizi kaydetmek için konumunuza erişir.",
        "NSMicrophoneUsageDescription": "Morider, grup sürüşlerinde sesli sohbet için mikrofonunuza erişir.",
        "UIBackgroundModes": [
          "location",
          "audio",
          "voip",
          "location",
          "audio",
          "voip"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false
    },
    "android": {
      "package": "app.morider.mobile",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.CAMERA",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Morider sürüşlerinizi kaydetmek için konumunuza erişir."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Morider, paylaşmak istediğin fotoğraflara erişir.",
          "cameraPermission": "Morider, profil fotoğrafı çekmek için kameraya erişir."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Morider, grup sürüşü davet QR kodunu okutmak için kameraya erişir."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc"
    ],
    "extra": {
      "eas": {
        "projectId": "f0603b97-8894-4003-8102-57f16d38bd78"
      }
    },
    "owner": "rascal98"
  }
}
